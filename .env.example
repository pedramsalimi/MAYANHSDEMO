# Copy this file to .env and fill in your credentials

# Azure OpenAI (GPT-4o-mini coaching agent)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Speech (TTS + STT)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_region_here
AZURE_SPEECH_VOICE=en-GB-LibbyNeural

# VAD tuning (optional — defaults shown)
MAYA_VOICE_SAMPLE_RATE=16000
MAYA_VAD_FRAME_MS=30
MAYA_VAD_AGGRESSIVENESS=1
MAYA_VAD_SILENCE_MS=700
MAYA_VAD_MAX_UTTERANCE_MS=20000
